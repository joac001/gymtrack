# Base de datos MongoDB Atlas
MONGODB_URI=mongodb+srv://<usuario>:<contraseña>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority

# NextAuth — generá un secret con: openssl rand -base64 32
NEXTAUTH_SECRET=tu-secret-aqui

# URL de la app (localhost para desarrollo, dominio real para producción)
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — crear credenciales en console.cloud.google.com
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret

# Gemini (Google AI) — obtener en aistudio.google.com
GEMINI_API_KEY=tu-gemini-api-key
