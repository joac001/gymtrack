# Base de datos MongoDB Atlas
MONGODB_URI=

# NextAuth — generá un secret con: openssl rand -base64 32
NEXTAUTH_SECRET=

# URL de la app
NEXTAUTH_URL=

# Google OAuth — crear credenciales en console.cloud.google.com
# Authorized redirect URI: http://<dominio>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gemini (Google AI) — obtener en aistudio.google.com
GEMINI_API_KEY=